# PowerTrace backend environment
DEFAULT_VOLTAGE=127
OUTPUT_DIR=output
LOG_LEVEL=INFO
MAX_GENERATION_ATTEMPTS=3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=sqlite:///powertrace.db

# Generate a random value with at least 32 characters for each environment.
