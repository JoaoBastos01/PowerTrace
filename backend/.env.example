# PowerTrace backend environment
DEFAULT_VOLTAGE=127
OUTPUT_DIR=output
LOG_LEVEL=INFO
MAX_GENERATION_ATTEMPTS=3000

DATABASE_URL=sqlite:///powertrace.db

# Generate a random value with at least 32 characters for each environment.
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Optional initial account created by the first Alembic migration.
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_NAME=Administrator
BOOTSTRAP_USER_PASSWORD=replace-with-a-strong-password
