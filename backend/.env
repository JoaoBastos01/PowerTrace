# PowerTrace Backend — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores conforme necessário.

# Voltagem padrão monofásica (127 ou 220)
DEFAULT_VOLTAGE=127

# Diretório de saída para arquivos DXF gerados
OUTPUT_DIR=output

# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Número máximo de tentativas na geração de planta
MAX_GENERATION_ATTEMPTS=50

DATABASE_URL=sqlite:///powertrace.db

APP_USERNAME=admin
APP_PASSWORD=password
SECRET_KEY=123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=120